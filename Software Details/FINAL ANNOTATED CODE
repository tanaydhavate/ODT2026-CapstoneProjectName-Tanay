# ══════════════════════════════════════════════════════════════════════════════
# ADC IDENTIFICATION TABLE
# Maps averaged ADC voltage ranges to Pokémon.
# Ranges are spaced ~50–80 units apart to prevent misidentification
# even if the connector has slight resistance variation from wear.
# ══════════════════════════════════════════════════════════════════════════════

def identify_and_play(adc_val, oled, rangeela):
    if   50  <= adc_val <= 80:    return play_snivy(oled, rangeela)
    elif 160 <= adc_val <= 190:   return play_vaporeon(oled, rangeela)
    elif 210 <= adc_val <= 245:   return play_raichu(oled, rangeela)
    elif 370 <= adc_val <= 420:   return play_umbreon(oled, rangeela)
    elif 510 <= adc_val <= 550:   return play_pikachu(oled, rangeela)
    elif 640 <= adc_val <= 690:   return play_mudkip(oled, rangeela)
    elif 750 <= adc_val <= 800:   return play_mew(oled, rangeela)
    elif 870 <= adc_val <= 910:   return play_jigglypuff(oled, rangeela)
    elif 980 <= adc_val <= 1010:  return play_gengar(oled, rangeela)
    elif 1080 <= adc_val <= 1110: return play_spheal(oled, rangeela)
    else:
        # No figure matched — show the raw ADC value to help debug connector issues
        oled_message(oled, "Unknown", "ADC:" + str(adc_val), "Try again")
        rangeela_clear(rangeela)
        sleep(2)
        return None, None

# ══════════════════════════════════════════════════════════════════════════════
# MAIN STATE MACHINE
# The core loop: Boot → Standby → Scan → Reveal → Catch → Result → Reset
# Runs forever until power is cut or POOPER long-press triggers a reboot.
# ══════════════════════════════════════════════════════════════════════════════

def main():
    print("Pokedex standby - waiting for BOOT press")

    # Initialise all hardware in sequence — order matters.
    # SD card first so all other init functions can log errors to serial.
    spi, sd            = init_sd()
    rangeela           = init_neopixel()
    i2c, oled          = init_oled()
    adc                = init_adc()
    pooper, butter     = init_buttons()
    motor_ena, motor_in1, motor_in2 = init_motor()

    # Wait for POOPER press before starting — device stays dark until user initiates
    while pooper.value() == 1:
        sleep_ms(50)
    wait_for_button_release(pooper)

    boot_animation(oled, rangeela)  # visual confirmation that boot is complete

    while True:
        # ── STANDBY ──
        oled_message(oled, "POKEDEX", "Ready to Scan", "Press SCAN")
        rangeela_clear(rangeela)

        while True:
            if check_long_press(pooper, LONG_PRESS_MS):
                # 2-second hold on POOPER → reboot
                oled_message(oled, "Rebooting...")
                rangeela_clear(rangeela)
                sleep(1)
                reset()
            if butter.value() == 0:
                # BUTTER pressed → begin scan
                sleep_ms(50)  # debounce
                wait_for_button_release(butter)
                break

        # ── SCAN ──
        oled_message(oled, "Scanning...")
        scan_animation(rangeela)
        adc_val = read_adc_average(adc)
        print("ADC avg:", adc_val)
        oled_message(oled, "Scanning...", "ADC:" + str(adc_val))
        sleep_ms(500)  # brief pause so the user can read the ADC value on screen

        # ── IDENTIFY & REVEAL ──
        rangeela_clear(rangeela)
        pokemon_key, pokemon_name = identify_and_play(adc_val, oled, rangeela)

        # ── CATCH ──
        if pokemon_key is not None:
            rangeela_clear(rangeela)
            sleep_ms(300)
            try_catch(oled, rangeela, butter,
                      motor_ena, motor_in1, motor_in2,
                      pokemon_key, pokemon_name)

        # ── RESET ──
        rangeela_clear(rangeela)
        oled_message(oled, "Restarting...", "", "")
        sleep(2)
        gc.collect()  # free memory from frames and audio buffers before next round

# Wrap main() in try/except so any fatal crash prints the error
# instead of silently hanging — makes debugging much easier.
try:
    main()
except Exception as e:
    print("FATAL:", e)
