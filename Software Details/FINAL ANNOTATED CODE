import gc          # garbage collector — frees unused memory
import os          # file system access — needed to mount the SD card
import sdcard      # SD card driver library
import framebuf    # frame buffer — lets us draw pixels and bitmaps on the OLED
import urandom     # random number generator — used for the catch roll

from time import sleep_ms, sleep, ticks_ms, ticks_diff
# sleep_ms / sleep  → pause execution for a set time
# ticks_ms / ticks_diff → non-blocking timing (like a stopwatch) so we don't freeze the system

from machine import Pin, SPI, I2C, I2S, ADC, reset
# Pin   → controls GPIO pins (buttons, motor, LEDs)
# SPI   → communication protocol for the SD card
# I2C   → communication protocol for the OLED screen
# I2S   → audio protocol for the amplifier and speaker
# ADC   → reads analog voltage from the resistor in each figure
# reset → reboots the ESP32

from neopixel import NeoPixel   # NeoPixel LED driver
from SH1106 import SH1106_I2C   # OLED display driver

gc.collect()  # free memory before anything starts — good practice on a microcontroller

# ─── Pin Assignments ──────────────────────────────────────────────────────────
# These numbers refer to physical GPIO pins on the ESP32 board.
# Each peripheral needs specific pins — we mapped these carefully to avoid conflicts
# between SPI (SD card), I2C (OLED), I2S (audio), and GPIO (everything else).

SD_CS_PIN    = 5    # SD card chip select
SD_SCK_PIN   = 18   # SD card clock
SD_MOSI_PIN  = 23   # SD card data out (ESP32 → SD)
SD_MISO_PIN  = 19   # SD card data in  (SD → ESP32)

RANGEELA_PIN = 4    # NeoPixel LED data pin
# Renamed "rangeela" (रंगीला — colourful in Hindi) — fits the LED ring perfectly
NUM_LEDS     = 16   # 16 LEDs in the ring

OLED_SCL_PIN = 22   # OLED clock line (I2C)
OLED_SDA_PIN = 21   # OLED data line  (I2C)
OLED_ADDR    = 0x3C # I2C address of the OLED — fixed by hardware
OLED_W       = 128  # OLED width in pixels
OLED_H       = 64   # OLED height in pixels

I2S_SCK_PIN  = 26   # audio bit clock
I2S_WS_PIN   = 25   # audio word select (left/right channel)
I2S_SD_PIN   = 27   # audio data out to amplifier

ADC_PIN      = 33   # reads the resistor voltage from the plugged-in figure
# Pin 33 chosen after testing — most stable ADC reading, no boot mode conflicts

POOPER_PIN = 34     # BOOT button — wakes the device and triggers reboot
BUTTER_PIN = 35     # SCAN button — initiates scan and throw
# Pins 34 and 35 are input-only with no internal pull-up resistors on the ESP32.
# We added external pull-up resistors to make them work reliably as buttons.
# Renamed "pooper" and "butter" as team nicknames for boot and scan respectively.

MOTOR_ENA_PIN = 15  # motor enable (speed control)
MOTOR_IN1_PIN = 13  # motor direction pin 1
MOTOR_IN2_PIN = 14  # motor direction pin 2

# ─── Timing & Audio Constants ─────────────────────────────────────────────────
FRAME_WIDTH    = 128   # OLED width — matches display resolution
FRAME_HEIGHT   = 64    # OLED height — matches display resolution
FRAME_SIZE     = 1024  # bytes per frame (128 × 64 ÷ 8 = 1024 in MONO_HLSB format)
AUDIO_RATE     = 8000  # audio sample rate in Hz — low enough to fit files on SD card
AUDIO_BUF_SIZE = 8192  # I2S internal buffer — large enough to prevent audio glitches
MONO_BUF_SIZE  = 512   # how many bytes we read and send to the amp at a time
# 512 bytes was the sweet spot — smaller caused stuttering, larger caused lag

LONG_PRESS_MS  = 2000  # hold POOPER for 2s to reboot — long enough to avoid accidents
CATCH_PRESS_MS = 5000  # hold BUTTER for 5s to throw the Pokéball
ADC_SAMPLES    = 20    # number of ADC readings to average — reduces noise from the resistor circuit

SHAKE_ON_MS  = 120  # how long motor runs per direction during a shake (120ms)
SHAKE_GAP_MS = 90   # pause between forward and backward motor pulse

SHAKE_LABELS = ["Shake 1!", "Shake 2!", "Shake 3!"]  # text shown on OLED during each shake

